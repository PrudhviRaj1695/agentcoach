### Conditional Edges (Router вҶ’ Agent):
```python
def route_to_agent(state: AgentState) -> str:
    mode = state.get("current_mode", "chat")
    confidence = state.get("route_confidence", 0.0)
    
    if confidence < 0.7:
        return "clarify"          # Ask user to clarify
    
    routing_map = {
        "profile": "profile_agent",
        "planning": "planner_agent",
        "interviewing": "interviewer_agent",
        "evaluating": "evaluator_agent",
        "strategy": "strategy_agent",
        "chat": "general_chat",
    }
    return routing_map.get(mode, "general_chat")
```

